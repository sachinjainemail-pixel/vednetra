# Copy this file to ".env" and fill in your Zerodha Kite Connect credentials.
# These are ONLY needed when running with --feed kite or --broker kite.
# The default paper + simulated mode does NOT need any of these.

KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# The access token is generated daily via the login flow (see README).
# scripts/kite_login.py will write it here for you after you log in.
KITE_ACCESS_TOKEN=
